generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id               String            @id @default(cuid())
  name             String            @unique
  icon             String
  slug             String            @unique
  createdAt        DateTime          @default(now()) @map("created_at")
  businessRequests BusinessRequest[]
  businesses       Business[]

  @@map("categories")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  password         String
  name             String
  role             String            @default("VISITANTE")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  reviewedRequests BusinessRequest[] @relation("reviewedByRequests")
  businessRequests BusinessRequest[] @relation("userRequests")
  businesses       Business[]

  @@map("users")
}

model Business {
  id          String   @id @default(cuid())
  name        String
  description String?
  categoryId  String   @map("category_id")
  phone       String?
  whatsapp    String?
  address     String
  city        String   @default("La Victoria")
  state       String   @default("Aragua")
  country     String   @default("Venezuela")
  latitude    Float
  longitude   Float
  image       String?
  hours       String?
  verified    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  images      String[] @default([])
  ownerId     String?  @map("owner_id")
  category    Category @relation(fields: [categoryId], references: [id])
  owner       User?    @relation(fields: [ownerId], references: [id])
  businessImages BusinessImage[]

  @@index([categoryId])
  @@index([active])
  @@index([city])
  @@map("businesses")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("password_reset_tokens")
}

model BusinessRequest {
  id               String                @id @default(cuid())
  userId           String                @map("user_id")
  businessId       String?               @map("business_id")
  businessName     String                @map("business_name")
  categoryId       String                @map("category_id")
  address          String
  phone            String
  whatsapp         String
  description      String?
  openingHours     String?               @map("opening_hours")
  note             String?
  latitude         Float?
  longitude        Float?
  paymentReference String                @map("payment_reference")
  proofImageUrl    String?               @map("proof_image_url")
  createdAt        DateTime              @default(now()) @map("created_at")
  reviewedAt       DateTime?             @map("reviewed_at")
  reviewedById     String?               @map("reviewed_by_id")
  paymentMethod    PaymentMethod         @map("payment_method")
  status           BusinessRequestStatus @default(PENDING)
  plan             SubscriptionPlan?
  images           String[]              @default([])
  category         Category              @relation(fields: [categoryId], references: [id])
  reviewedBy       User?                 @relation("reviewedByRequests", fields: [reviewedById], references: [id])
  user             User                  @relation("userRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@map("business_requests")
}

model PaymentSettings {
  id            String   @id @default(cuid())
  monthlyPrice  Float    @map("monthly_price")
  yearlyPrice   Float    @map("yearly_price")
  currency      String   @default("USD")
  pagoMovilInfo String   @map("pago_movil_info")
  transferInfo  String   @map("transfer_info")
  binanceInfo     String   @map("binance_info")
  binanceNetwork  String?         @map("binance_network")
  binanceWallet   String?         @map("binance_wallet")
  binanceFeeType  BinanceFeeType? @map("binance_fee_type") // FIXED or PERCENTAGE
  binanceFeeValue Float?   @map("binance_fee_value")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("payment_settings")
}

enum PaymentMethod {
  PAGO_MOVIL
  TRANSFERENCIA
  BINANCE
}

enum BusinessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum BinanceFeeType {
  FIXED
  PERCENTAGE
}

model BusinessImage {
  id          String   @id @default(cuid())
  businessId  String   @map("business_id")
  url         String
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_images")
}
